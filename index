<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ระบบรับแจ้งงานบริการออนไลน์</title>
    <!-- Tailwind CSS สำหรับตกแต่ง UI ให้สวยงาม -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- SweetAlert2 สำหรับแสดง Popup แจ้งเตือน -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <!-- Font Noto Sans Thai -->
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Thai:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Noto Sans Thai', sans-serif;
            background-color: #f3f4f6;
        }
    </style>
</head>
<body class="antialiased text-gray-800 min-h-screen flex items-center justify-center p-4">

    <div class="max-w-lg w-full bg-white rounded-2xl shadow-xl overflow-hidden">
        
        <!-- Header -->
        <div class="bg-red-600 px-6 py-8 text-center">
            <div class="mx-auto bg-white/20 w-16 h-16 flex items-center justify-center rounded-full mb-4">
                <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                </svg>
            </div>
            <h2 class="text-2xl font-bold text-white">ระบบรับแจ้งงานบริการออนไลน์</h2>
            <p class="text-red-100 mt-2 text-sm">กรุณากรอกข้อมูลตามความเป็นจริง เพื่อความรวดเร็วในการดำเนินการ</p>
        </div>

        <!-- Form -->
        <div class="p-6 sm:p-8">
            <form id="complaintForm" onsubmit="submitForm(event)">
                
                <div class="mb-5">
                    <label for="name" class="block text-sm font-medium text-gray-700 mb-1">ชื่อ-นามสกุล (ผู้แจ้ง)</label>
                    <input type="text" id="name" name="name" required placeholder="นายอากาศ เย็นสบาย"
                        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500 outline-none transition-colors">
                </div>

                <div class="mb-5">
                    <label for="contact" class="block text-sm font-medium text-gray-700 mb-1">เบอร์โทรศัพท์ / ไอดีไลน์</label>
                    <input type="text" id="contact" name="contact" required placeholder="086-9595926 หรือ niasae.p"
                        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500 outline-none transition-colors">
                </div>

                <div class="mb-5">
                    <label for="subject" class="block text-sm font-medium text-gray-700 mb-1">หัวข้อที่ต้องการใช้บริการ</label>
                    <select id="subject" name="subject" required
                        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500 outline-none transition-colors bg-white">
                        <option value="" disabled selected>-- เลือกหัวข้อ --</option>
                        <option value="ติดตั้งแอร์">ติดตั้งแอร์</option>
                        <option value="ล้างแอร์">ล้างแอร์</option>
                        <option value="ซ่อมแอร์ (แอร์ไม่เย็น,น้ำหยด,มีเสียงดัง)">ซ่อมแอร์ (แอร์ไม่เย็น,น้ำหยด,มีเสียงดัง)"</option>
                        <option value="ย้าย/ถอดแอร์">ย้าย/ถอดแอร์</option>
                        <option value="อื่นๆ">อื่นๆ</option>
                    </select>
                </div>

                <div class="mb-6">
                    <label for="details" class="block text-sm font-medium text-gray-700 mb-1">รายละเอียดเพิ่มเติม</label>
                    <textarea id="details" name="details" rows="4" required placeholder="อธิบายรายละเอียดปัญหาที่คุณพบเจอ..."
                        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500 outline-none transition-colors resize-none"></textarea>
                </div>

                <button type="submit" id="submitBtn" 
                    class="w-full bg-red-600 hover:bg-red-700 text-white font-medium py-3 px-4 rounded-lg transition-colors flex justify-center items-center">
                    <span>ส่งข้อร้องเรียน</span>
                    <!-- Loading Spinner (ซ่อนไว้ตอนเริ่มต้น) -->
                    <svg id="loadingIcon" class="hidden animate-spin ml-2 h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                </button>
            </form>
        </div>
    </div>

    <script>
        function submitForm(event) {
            event.preventDefault(); // ป้องกันการ Refresh หน้าเว็บ
            
            const btn = document.getElementById('submitBtn');
            const loading = document.getElementById('loadingIcon');
            const form = document.getElementById('complaintForm');

            // เปลี่ยนปุ่มเป็นสถานะกำลังโหลด
            btn.disabled = true;
            btn.classList.add('opacity-75', 'cursor-not-allowed');
            loading.classList.remove('hidden');

            // เก็บข้อมูลจากฟอร์ม
            const formData = {
                name: document.getElementById('name').value,
                contact: document.getElementById('contact').value,
                subject: document.getElementById('subject').value,
                details: document.getElementById('details').value
            };

            // เรียกใช้ฟังก์ชันฝั่ง Server (code.gs)
            google.script.run
                .withSuccessHandler(function(response) {
                    // ปรับปุ่มกลับมาเหมือนเดิม
                    btn.disabled = false;
                    btn.classList.remove('opacity-75', 'cursor-not-allowed');
                    loading.classList.add('hidden');

                    if (response.status === 'success') {
                        // แสดง Alert สำเร็จ
                        Swal.fire({
                            icon: 'success',
                            title: 'สำเร็จ!',
                            text: response.message,
                            confirmButtonColor: '#16a34a'
                        });
                        form.reset(); // ล้างฟอร์ม
                    } else {
                        // แสดง Alert แจ้งข้อผิดพลาด
                        Swal.fire({
                            icon: 'error',
                            title: 'เกิดข้อผิดพลาด',
                            text: response.message,
                            confirmButtonColor: '#dc2626'
                        });
                    }
                })
                .withFailureHandler(function(error) {
                    btn.disabled = false;
                    btn.classList.remove('opacity-75', 'cursor-not-allowed');
                    loading.classList.add('hidden');
                    
                    Swal.fire({
                        icon: 'error',
                        title: 'การเชื่อมต่อขัดข้อง',
                        text: 'ไม่สามารถติดต่อเซิร์ฟเวอร์ได้ กรุณาลองใหม่อีกครั้ง',
                        confirmButtonColor: '#dc2626'
                    });
                })
                .submitComplaint(formData); // ส่งข้อมูลไปให้ฟังก์ชัน submitComplaint
        }
    </script>
</body>
</html>
